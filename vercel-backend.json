{
  "version": 2,
  "name": "ai-news-dashboard-backend",
  "builds": [
    {
      "src": "backend/requirements.prod.txt",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.12",
    "DATABASE_URL": "@database_url",
    "GROQ_API_KEY": "@groq_api_key",
    "ENVIRONMENT": "production"
  },
  "functions": {
    "backend/api/index.py": {
      "runtime": "python3.12",
      "includeFiles": "backend/**"
    }
  }
}
