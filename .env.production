# ──────────────────────────────────────────────────────────────────────────────
# AI News Dashboard — Production Environment Variables
# NEVER commit this file to version control
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Production PostgreSQL database (Render or your provider)
DATABASE_URL=postgresql+asyncpg://username:password@hostname:port/database_name

# ── Groq LLM (Required for AI features) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── News Ingestion ────────────────────────────────────────────────────────────
FETCH_INTERVAL_MINUTES=15
MAX_ITEMS_PER_SOURCE=50

# ── Email Broadcast (Optional) ────────────────────────────────────────────────
# Configure for production email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-email@gmail.com
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# ── LinkedIn Integration (Optional) ────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# ── WhatsApp Integration (Optional) ───────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/your-phone-number-id/messages
WHATSAPP_API_KEY=your_whatsapp_api_key

# ── General Production Settings ───────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
